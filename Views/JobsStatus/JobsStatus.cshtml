<script>
     $(document).ready(function () {
        var today = new Date().toISOString().split('T')[0];
        $("#initiated_from").val(today);
        $("#initiated_to").val(today);
        $("#navhead").text("Jobs In Queue");
        searchJob();
        $('#navhead').text('Jobs Status');
        var ipoName = localStorage.getItem("selectedIPOText");
        $("#iponame").val(ipoName);   
      });     

     function searchJob(){
            var fromDate = validateDateFormat($("#initiated_from").val());
            var toDate = validateDateFormat($("#initiated_to").val());
             if (fromDate && toDate) {
                try {
                   // var job_type = type;
                    var period_from = $("#initiated_from").val();
                    var start_date = period_from;
                    var period_end = $("#initiated_to").val();
                    var end_date = period_end;
                    var action_by = '@userName'; //sessionStorage.getItem("usrname");
                    $.ajax({
                        type: "POST",
                        url: '../JobsStatus/QueueListFetch',
                        dataType: 'json',
                        data: JSON.stringify({ in_start_date: start_date, in_end_date: end_date, in_jobstatus: 'I', in_user_code: action_by }),
                        contentType: 'application/json; charset=utf-8',
                        success: function (response) {
                            if (response != null || (response.length) > 0) {
                                    $("#gd_inQueueList").empty();
                                    $("#gd_inQueueList").append("<div id='inQueueList'></div>");
                                    fetchInQueueGrid(response);                                
                            }
                            else {
                                fetchInQueueGrid([]);
                            }
                        },
                        error: function (er) {
                            alert(er)
                            console.log(er)
                        }

                    });
                }
                catch (e) {
                    console.log(e)
                }
            } else if (!fromDate || !toDate) {
                $.alert({
                    title: 'Recon',
                    content: "Invalid Date ..!",
                    type: 'red',
                });
            }
    }

    function jobinprogress(){
         var fromDate = validateDateFormat($("#initiated_from_ip").val());
         var toDate = validateDateFormat($("#initiated_to_ip").val());        
          if (fromDate && toDate) {
              var start_date = $("#initiated_from_ip").val();
              var end_date = $("#initiated_to_ip").val();              
                try {
                    var action_by = '@userName';
                    $.ajax({
                        type: "POST",
                        url: '../JobsStatus/getjobinprogresslist',
                        dataType: 'json',
                        data: JSON.stringify({ in_start_date: start_date, in_end_date: end_date, in_jobtype_code: '0', in_jobstatus: 'P', in_user_code: action_by }),
                        contentType: 'application/json; charset=utf-8',
                        success: function (response) {
                            if (response != null || (response.length) > 0) {                               
                                    $("#gd_inProgressList").empty();
                                    $("#gd_inProgressList").append("<div id='inProgressList'></div>");
                                    fetchInProgressGrid(response);                                
                            }
                            else {
                                fetchInProgressGrid([]);
                            }
                        },
                        error: function (er) {
                            alert(er)
                            console.log(er)
                        }

                    });
                }
                catch (e) {
                    console.log(e)
                }
            } else if (!fromDate || !toDate) {
                $.alert({
                    title: 'Recon',
                    content: "Invalid Date ..!",
                    type: 'red',
                });
            }
    }

    function jobcompleted(){
         var fromDate = validateDateFormat($("#initiated_from_c").val());
         var  toDate = validateDateFormat($("#initiated_to_c").val());
          if (fromDate && toDate) {
              var start_date =  $("#initiated_from_c").val();
              var end_date = $("#initiated_to_c").val();              
                try {
                    var action_by = '@userName';
                    $.ajax({
                        type: "POST",
                        url: '../JobsStatus/Joblistfetch',
                        dataType: 'json',
                        data: JSON.stringify({ in_start_date: start_date, in_end_date: end_date, in_jobtype_code: '0', in_jobstatus: 'C', in_user_code: action_by }),
                        contentType: 'application/json; charset=utf-8',
                        success: function (response) {
                            if (response != null || (response.length) > 0) {                               
                                    $("#gd_completedList").empty();
                                    $("#gd_completedList").append("<div id='completedList'></div>");
                                    fetchCompletedGrid(response);                                
                            }
                            else {
                                fetchCompletedGrid([]);
                            }
                        },
                        error: function (er) {
                            alert(er)
                            console.log(er)
                        }

                    });
                }
                catch (e) {
                    console.log(e)
                }
            } else if (!fromDate || !toDate) {
                $.alert({
                    title: 'Recon',
                    content: "Invalid Date ..!",
                    type: 'red',
                });
            }
    }

    function fetchInQueueGrid(data){
            $("#inQueueList").kendoGrid({
                dataSource: {
                    data: data,
                    pageSize: 10
                },
                height: 300,
                sortable: true,
                pageable: true,
                columns: [
                    { field: "in_koqueue_gid", title: "Queue ID" },
                    { field: "recon_name", title: "IPO Name" },
                    { field: "queue_name", title: "Scheduled Job" },
                    { field: "scheduled_date", title: "Scheduled Date" },
                    { field: "in_koqueue_remark", title: "Remarks" },
                    { field: "scheduled_by", title: "Scheduled By" },
                    { field: "jobstatus_desc", title: "Job Status" }
                ]
            });
    }

    function fetchInProgressGrid(data){
         $("#inProgressList").kendoGrid({
                dataSource: {
                    data: data,
                    pageSize: 10
                },
                height: 300,
                sortable: true,
                pageable: true,

                columns: [
                    { field: "job_gid", title: "Queue ID" },
                    { field: "job_name", title: "Job Name" },
                    { field: "jobtype_desc", title: "Job Type" },
                    { field: "job_name", title: "IPO Name" },
                    { field: "start_date", title: "Start Date" },
                   { field: "job_initiated_by", title: "Initiated By" },
                    { field: "job_remark", title: "Job Remarks" }
                ]
            });
    }

    function fetchCompletedGrid(data){
         $("#completedList").kendoGrid({
                dataSource: {
                    data: data,
                    pageSize: 10
                },
                height: 300,
                sortable: true,
                pageable: true,
                columns: [
                    { field: "job_gid", title: "Job ID" },
                    { field: "job_name", title: "Job Name" },
                    { field: "jobtype_desc", title: "Job Type" },
                    { field: "recon_name", title: "IPO Name" },
                    { field: "start_date", title: "Start Date" },
                    { field: "end_date", title: "End Date" },
                    { field: "job_remark", title: "Job Remarks" },
                   { field: "job_initiated_by", title: "Initiated By" },
                   { field: "jobstatus_desc", title: "Job Status" }
                ]
            });
    }

    function queueTab() {
        var today = new Date().toISOString().split('T')[0];
        $("#initiated_from").val(today);
        $("#initiated_to").val(today);
    }

    function progressTab() {
        var today = new Date().toISOString().split('T')[0];
        $("#initiated_from_ip").val(today);
        $("#initiated_to_ip").val(today);
        jobinprogress();
    }

     function completedTab() {
        var today = new Date().toISOString().split('T')[0];
        $("#initiated_from_c").val(today);
        $("#initiated_to_c").val(today);
        jobcompleted();
    }
   
</script>