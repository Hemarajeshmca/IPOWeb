        </div>

        <!-- Change Password Modal -->
        <div class="modal fade" id="changePasswordModal" tabindex="-1" role="dialog" aria-labelledby="changePasswordModalLabel" aria-hidden="true">
            <div class="modal-dialog" role="document">
                <div class="modal-content" style="border-radius:10px">
                    <div class="modal-header" style="background-color:#0e9ac8;color:white;">
                        <h5 class="modal-title" id="changePasswordModalLabel" style="margin-bottom:-16px;">Change Password</h5>
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close" style="color:white">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        <form id="changePasswordForm">
                            <input type="hidden" id="changePasswordEmail" />
                            <div class="form-group">
                                @* <span class="input-group-addon"><i class="glyphicon glyphicon-user"></i></span> *@
                                <label for="oldPassword">Enter OTP</label>
                                <input type="password" class="form-control" id="oldPassword" required>
                                <span id="queryErrorOldPwd" style="color: red; font-size: 12px;position:relative;"></span>
                            </div>
                            <span id="oldError" style="color: red; font-size: 12px;position:relative;top:-14px;"></span>
                            <div class="form-group">
                                @* <span class="input-group-addon"><i class="glyphicon glyphicon-user"></i></span> *@
                                <label for="newPassword">New Password</label>
                                <input type="password" class="form-control" id="newPassword" required>
                                @* <small id="oldPwdError" class="form-text text-danger"></small> *@
                            </div>
                            <span id="newError" style="color: red; font-size: 12px;position:relative;top:-14px;"></span>
                            <div class="form-group">
                                @* <span class="input-group-addon"><i class="glyphicon glyphicon-user"></i></span> *@
                                <label for="confirmPassword">Confirm New Password</label>
                                <input type="password" class="form-control" id="confirmPassword" required>
                                <span id="queryErrorAllEmpty" style="color: red; font-size: 12px;position:relative;"></span>
                                <span id="queryErrorNewCnfPwd" style="color: red; font-size: 12px;position:relative;"></span>
                            </div>
                            <span id="conError" style="color: red; font-size: 12px;position:relative;top:-14px;"></span>
                            <div class="text-center">
                                <button type="button" class="btn btn-success" onclick="saveNewPassword()">Save</button>
                            </div>
                            
                        </form>
                    </div>
                </div>
            </div>
        </div>       

    </div>
</body>
</html>

