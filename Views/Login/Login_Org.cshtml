<script>
    function generate16DigitRandomNumber() {
        let randomNumber = '';
        for (let i = 0; i < 16; i++) {
            randomNumber += Math.floor(Math.random() * 10); // Concatenate a random digit (0-9)
        }
        return randomNumber;
    }

        function saveNewPassword() {
        debugger;

        var empcode = $('#changePasswordEmail').val();
        var oldPwd = $("#oldPassword").val();
        var newPwd = $("#newPassword").val();
        var confirmPwd = $("#confirmPassword").val();
        var txt_pwd = $("#txtpwd").val();

        var data = {
            old_pwd: oldPwd,
            new_pwd: newPwd,
            empCode: empcode,
            con_pwd: confirmPwd
        };

        $.ajax({
            url: '@Url.Action("ChangePassword", "Login")',
            type: 'POST',
            data: JSON.stringify(data),
            contentType: 'application/json',
            success: function (response) {
                console.log("Response:", response);

                    if (response.success) {
                        $.dialog({
                            title: 'Success',
                            content: response.message,
                            type: 'green',
                            onClose: function () {
                                $("#changePasswordForm")[0].reset();
                                location.reload();
                            }
                        });
                    } else {
                        $.dialog({
                            title: 'Error',
                            content: response.message,
                            type: 'red'
                        });
                    }
            },
            error: function (error) {
                console.error("Error:", error);
                alert("Error changing password");
            }
        });
    }


    function CheckLogin() {
        debugger;
        var empCode = $("#txtusername").val();
        var txt_pwd = $("#txtpwd").val();

        if (empCode == "") {
            $(".errormessage").html('<span class="errormessage"  id="mess">Please Enter Employee Code...!!</span>');
            $("#erridmsg").show();
            return false;
        }
        if (txt_pwd == "") {
            $(".errormessage").html('<span class="errormessage"  id="mess">Please Enter Password...!!</span>');
            $("#erridmsg").show();
            return false;
        }
        

        $.ajax({
            url: '@Url.Action("GetChngPwdFlag", "Login")?empCode=' + empCode,
            type: 'POST',
            contentType: 'application/json',
            success: function (response) {
                debugger;
                var _data = JSON.parse(response).Table;
                console.log(_data);

                let url = ''; // Declare outside to avoid scope issues

                if (_data.length == 0){
                    $.alert({
                            title: 'Error',
                            content: 'Please Enter Correct Employee Code',
                            type: 'red'
                        });
                        return;
                }

                if (_data.length > 0) {
                    var flag = _data[0].password_changed_flag;
                    var pwd = _data[0].password;

                    if (pwd !== txt_pwd) {
                        $.alert({
                            title: 'Error',
                            content: 'Please Enter Correct Password',
                            type: 'red'
                        });
                        return; // Prevent further execution
                    } else if (flag === "Y") {
                        $('#changePasswordEmail').val(empCode);
                        $('#changePasswordModal').modal('show');
                            var oldlength = $('#oldPassword').val().length;
                            var newlength = $('#newPassword').val().length;
                            var conlength = $('#confirmPassword').val().length;

                            var oldpwd = document.getElementById("oldPassword").value.trim();
                            var newpwd = document.getElementById("newPassword").value.trim();
                            var conpwd = document.getElementById("confirmPassword");
                            var isValid = true;

                            
                            oldError.textContent = "";
                            newError.textContent = "";
                            conError.textContent = "";

                            if (oldlength < 6 || newlength < 6 ||conlength < 6) {
                                $('#errorMsg').text("Minimum 6 characters required.");
                            } else {
                                $('#errorMsg').text("");
                            }


                            // if(oldpwd === "" || newpwd === "" || conpwd === ""){
                            //     allerror.textContent = "All fields required";
                            //     return;
                            // }
                                return;
                            

                         // Prevent redirect
                    } else {
                        url = '@Url.Action("Registration", "Registration")';
                    }

                    // Move this inside else so it only executes if url is set
                    window.location.href = url;
                }
                else {
                    $("#OTPbtn").css('display', '');
                    $("#resendOtp").css('display', 'none');
                    $("#loginbtn").css('display', '');
                    $("#btnGenerateOtp").css('display','none');
                    $("#otpdiv").css('display', '');
                    $.alert({
                        title: 'Error',
                        content: _data[0].Msg,
                        type: 'red',
                    });
                }

            },
            error: function (xhr, status, error) {
                $("#OTPbtn").css('display', '');
                $("#resendOtp").css('display', 'none');
                $("#loginbtn").css('display', 'none');
                // Handle error
                $.alert({
                    title: ' ',
                    content: "RowFilters Failed to Save.!",
                    type: 'red',
                });
            }
        });


        // Function to populate dropdown
        function populateDropdown(data,id,value = 'default',text = 'default') {
            debugger;
            var dropdown = $('#'+id);

            // Clear existing options
            dropdown.empty();

            // Add default option if needed
            dropdown.append('<option value="0" selected>--Select--</option>');

            // Add options based on data
            $.each(data, function (index, item) {
                if(data.count == 1){
                    dropdown.append($('<option selected></option>').attr('value', item.entity_id).text(item.entity_name));
                }else{
                    dropdown.append($('<option></option>').attr('value', item.entity_id).text(item.entity_name));
                }
            });
        }

