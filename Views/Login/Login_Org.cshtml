    function GenerateOtp() {
        debugger;
        $("#OTPbtn").css('display', 'none');
        $("#resendOtp").css('display', '');
        $("#loginbtn").css('display', '');
        $("#otpdiv").css('display', '');
        $.ajax({
            url: '@Url.Action("generateOTP", "Login")?empCode=' + $("#txtusername").val(),
            type: 'POST',
            contentType: 'application/json',
            // data: JSON.stringify({ selectedData: getModel }),// JSON.stringify({ jsonArray: jsonArray }),
            success: function (response) {
                console.log(response);
                var _data = JSON.parse(response);
                if (_data[0].Clear == 1) {
                    $("#OTPbtn").css('display', 'none');
                    $("#resendOtp").css('display', '');
                    $("#loginbtn").css('display', '');
                    $("#otpdiv").css('display', '');

                    // Handle success
                    $.alert({
                        title: 'Success',
                        content: _data[0].Msg,
                        type: 'green',
                    });
                } else {
                    $("#OTPbtn").css('display', '');
                    $("#resendOtp").css('display', 'none');
                    $("#loginbtn").css('display', 'none');
                    $("#otpdiv").css('display', 'none');
                    $.alert({
                        title: 'Error',
                        content: _data[0].Msg,
                        type: 'red',
                    });
                }

            },
            error: function (xhr, status, error) {
                $("#OTPbtn").css('display', '');
                $("#resendOtp").css('display', 'none');
                $("#loginbtn").css('display', 'none');
                // Handle error
                $.alert({
                    title: ' ',
                    content: "RowFilters Failed to Save.!",
                    type: 'red',
                });
            }
        });
    }
