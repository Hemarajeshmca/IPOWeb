<script>
    function generate16DigitRandomNumber() {
        let randomNumber = '';
        for (let i = 0; i < 16; i++) {
            randomNumber += Math.floor(Math.random() * 10); // Concatenate a random digit (0-9)
        }
        return randomNumber;
    }

    function saveNewPassword() {
        debugger;
        var isValid = true;
        var empcode = $('#changePasswordEmail').val();
        var oldPwd = $("#oldPassword").val();
        var newPwd = $("#newPassword").val();
        var confirmPwd = $("#confirmPassword").val();
        var txt_pwd = $("#txtpwd").val();
        const minLength = 6;

        var data = {
            old_pwd: oldPwd,
            new_pwd: newPwd,
            empCode: empcode,
            con_pwd: confirmPwd
        };

        if (oldPwd === "" || newPwd === "" || confirmPwd === "") {
            queryErrorAllEmpty.textContent = "All Fields Required";
            isValid = false;
        }else {
            queryErrorAllEmpty.textContent = ""; // Clear any previous error
        }

        if (oldPwd!= "" && oldPwd != txt_pwd){
            queryErrorOldPwd.textContent = "Old Password Not Same";
            isValid = false;
        }else {
            queryErrorOldPwd.textContent = ""; // Clear any previous error
        }

        if (newPwd != confirmPwd){
            queryErrorNewCnfPwd.textContent = "New Password And Confirm Password Not Same";
            isValid = false;
        }else if (newPwd != "" && confirmPwd != "" &&(newPwd.length < minLength || confirmPwd < minLength)) {
            queryErrorNewCnfPwd.textContent = "New And Confirm Password must be at least " + minLength + " characters long";
            isValid = false;
        }else {
            queryErrorNewCnfPwd.textContent = ""; // Clear any previous error
        }


        if(isValid) {
            $.ajax({
                url: '@Url.Action("ChangePassword", "Login")',
                type: 'POST',
                data: JSON.stringify(data),
                contentType: 'application/json',
                success: function (response) {
                    console.log("Response:", response);

                    if (response.success) {
                        $.dialog({
                            title: 'Success',
                            content: response.message,
                            type: 'green',
                            onClose: function () {
                                $("#changePasswordForm")[0].reset();
                                location.reload();
                            }
                        });
                    } else {
                        $.dialog({
                            title: 'Error',
                            content: response.message,
                            type: 'red'
                        });
                    }
                },
                error: function (error) {
                    console.error("Error:", error);
                    alert("Error changing password");
                }
            });
        }
    }
    function CheckLogin() {
        var empCode = $("#txtusername").val();
        var txt_pwd = $("#txtpwd").val();
        if (empCode == "") {
            $(".errormessage").html('<span class="errormessage"  id="mess">Please Enter Username...!!</span>');
            $("#erridmsg").show();
            return false;
        }
        if (txt_pwd == "") {
            $(".errormessage").html('<span class="errormessage"  id="mess">Please Enter Password...!!</span>');
            $("#erridmsg").show();
            return false;
        }

            $.ajax({
                url: '@Url.Action("ChkLogin", "Login")?empCode=' + empCode + '&txt_pwd=' + txt_pwd,
                type: 'POST',
                dataType: 'json',              // ⭐ REQUIRED
                success: function (response) {

                  if (typeof response === "string") {
                    response = JSON.parse(response);
                }

                // SAFETY CHECK
                if (!response.Table || response.Table.length === 0) {
                    console.error("Table missing or empty", response);
                    return;
                }

                var data = response.Table[0];
                console.log("USER NAME:", data.user_name);

                    // FAILURE
                    if (data.success === 0) {
                        $(".errormessage").html(
                            `<span class="errormessage">${data.message}</span>`
                        );
                        $("#erridmsg").show();
                        return;
                    }

                    // SUCCESS ✅
                    if (data.success === 1) {
                        sessionStorage.setItem("user_id", data.user_id);
                        sessionStorage.setItem("user_name", data.user_name);
                        sessionStorage.setItem("role_code", data.role_code);

                        window.location.href = '@Url.Action("Dashboard", "Dashboard")';
                    }
                },
                error: function () {
                    $.alert({
                        title: 'Error',
                        content: 'Login request failed',
                        type: 'red'
                    });
                }
            });
    }

    function ForgotPassword() {
        debugger;
        var url = '@Url.Action("ForgotPassword", "Login")'
        window.location.href = url;
        //window.location.href = '../login/ForgetPassword';
    }

    function GenerateOtp() {
        debugger;
        $("#OTPbtn").css('display', 'none');
        $("#resendOtp").css('display', '');
        $("#loginbtn").css('display', '');
        $("#otpdiv").css('display', '');
        $.ajax({
            url: '@Url.Action("generateOTP", "Login")?empCode=' + $("#txtusername").val(),
            type: 'POST',
            contentType: 'application/json',
            // data: JSON.stringify({ selectedData: getModel }),// JSON.stringify({ jsonArray: jsonArray }),
            success: function (response) {
                console.log(response);
                var _data = JSON.parse(response);
                if (_data[0].Clear == 1) {
                    $("#OTPbtn").css('display', 'none');
                    $("#resendOtp").css('display', '');
                    $("#loginbtn").css('display', '');
                    $("#otpdiv").css('display', '');

                    // Handle success
                    $.alert({
                        title: 'Success',
                        content: _data[0].Msg,
                        type: 'green',
                    });
                } else {
                    $("#OTPbtn").css('display', '');
                    $("#resendOtp").css('display', 'none');
                    $("#loginbtn").css('display', 'none');
                    $("#otpdiv").css('display', 'none');
                    $.alert({
                        title: 'Error',
                        content: _data[0].Msg,
                        type: 'red',
                    });
                }

            },
            error: function (xhr, status, error) {
                $("#OTPbtn").css('display', '');
                $("#resendOtp").css('display', 'none');
                $("#loginbtn").css('display', 'none');
                // Handle error
                $.alert({
                    title: ' ',
                    content: "RowFilters Failed to Save.!",
                    type: 'red',
                });
            }
        });
    }
    $(document).ready(function () {

        $("#OTPbtn").css('display', ''); // commented by hari for dev env

        if ("@ViewBag.isMultiDatabase" == "true") {
            $("#divEntity").show();
        }
        else {
            $("#divEntity").hide();
        }
    });



</script>