@{
    var userRole = Context.Session.GetString("user_role");
    var userId = Context.Session.GetString("user_id");
    var userName = Context.Session.GetString("user_name");
    var userCode = Context.Session.GetString("user_code");
    var userEmail = Context.Session.GetString("user_email");
    var roleName = Context.Session.GetString("role_name");
    var menuJson = Context.Session.GetString("UserMenus");
    var menus = new List<MenuModel>();
    var asideMenus = new List<MenuModel>(); 
    var navMenus = new List<MenuModel>();

    if (!string.IsNullOrEmpty(menuJson))
    {
        menus = System.Text.Json.JsonSerializer.Deserialize<List<MenuModel>>(menuJson);
        asideMenus = menus.Where(x => x.menu_type == "aside").ToList();
        navMenus = menus.Where(x => x.menu_type == "nav").ToList();
    }
}
