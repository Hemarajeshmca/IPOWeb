                 spinnerVisible = false;
                 $("div.k-grid").each(function () {
                    var grid = $(this).data("kendoGrid");
                    if (grid) {
                        var isSortable = grid.options.sortable;
                        var isFilterable = grid.options.filterable;
                        if (!isSortable || !isFilterable) {
