                border-bottom: 1px solid #dcdcdc;
            }
        /* Cell borders */
        #issueListGrid td {
            border: 1px solid #cfd8dc;
        }

        #issueListGrid .k-grid-content tr:last-child td {
            border-bottom: 1px solid #dcdcdc !important;
        }

        /* Cell borders */
        #issueListGrid td {
            border: 1px solid #cfd8dc;
        }

        /* Compact row height */
        #issueListGrid .k-grid-content td {
            padding-top: 2px;
            padding-bottom: 2px;
        }

        /* Fixed layout */
        #issueListGrid .k-grid-header table,
        #issueListGrid .k-grid-content table {
            table-layout: fixed;
            width: 100%;
        }

        /* Prevent wrapping */
        #issueListGrid .k-grid-header th,
        #issueListGrid .k-grid-content td {
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        #issueListGrid .k-grid-content td {
            padding-top: 2px;
            padding-bottom: 2px;
            line-height: 18px;
            font-size: 13px;
        }

        #issueListGrid .k-grid-header th {
            padding-top: 4px;
            padding-bottom: 4px;
            line-height: 18px;
            font-size: 13px;
        }

        #issueListGrid .k-grid-content {
            height: 330px !important;
        }

        .nav-align-top.mb-4 {
            margin-top: -17px;
        }
    </style>
</head>

