<script type="text/javascript" src="https://www.gstatic.com/charts/loader.js"></script>
<script>    
     $( document ).ready(function() {
          $('#navhead').text('Dashboard');
          const urlParams = new URLSearchParams(window.location.search);
            const tab = urlParams.get('tab');

        if (tab === "client") {

            // Activate Client Listing tab button
            var triggerEl = document.querySelector('[data-bs-target="#navs-top-client"]');
            var tabInstance = new bootstrap.Tab(triggerEl);
            tabInstance.show();
            history.replaceState(null, null, window.location.pathname);
        } else if (tab === "issue") {
            // Activate Client Listing tab button
            var triggerEl = document.querySelector('[data-bs-target="#navs-top-issue"]');
            var tabInstance = new bootstrap.Tab(triggerEl);
            tabInstance.show();
            history.replaceState(null, null, window.location.pathname);
        }
    }); 

     google.charts.load("current", {packages:["corechart"]});
      google.charts.setOnLoadCallback(drawChart);
      function drawChart() {
        var data = google.visualization.arrayToDataTable([
          ['Task', 'Hours per Day'],
          ['Companies',     11],
          ['Issues',      2],
          ['Mainboard IPO',  2],
          ['SME IPOs', 2]         
        ]);

        var options = {
          title: 'IPO Details',
          is3D: true,
        };

        var chart = new google.visualization.PieChart(document.getElementById('piechart_3d'));
        chart.draw(data, options);
      }


     google.charts.load('current', {'packages':['corechart']});
      google.charts.setOnLoadCallback(drawCharts);

      function drawCharts() {
        var data = google.visualization.arrayToDataTable([
          ['Year', 'IPOs Listed', 'IPOs Completed'],
          ['2004',  1000,      400],
          ['2005',  1170,      460],
          ['2006',  660,       1120],
          ['2007',  1030,      540]
        ]);

        var options = {
          title: 'IPO Reports',
          curveType: 'function',
          legend: { position: 'bottom' }
        };

        var chart = new google.visualization.LineChart(document.getElementById('curve_chart'));

        chart.draw(data, options);
      }

    var issueGridLoaded = false;
    

    $('button[data-bs-target="#navs-top-issue"]').on('shown.bs.tab', function () {

        if (!issueGridLoaded) {

            $("#issueListGrid").kendoGrid({
                dataSource: {
                    transport: {
                        read: {
                            url: "@Url.Action("GetIssueList", "IssueSetup")",
                            dataType: "json"
                        }
                    },
                    pageSize: 5
                },
                pageable: true,
                sortable: true,
                filterable: true,
                height: 400,
                columns: [
                    { field: "issueCode", title: "Offer Code" },
                    { field: "clientName", title: "Client Name" },
                    { field: "issueType", title: "Offer Type" },
                    { field: "listing", title: "Listing" },                  
                    { field: "issueStatus", title: "Offer Status" },
                    {
                        title: "Action",
                        template:
                           "<center>" +                          
                              "<img src='../Assets/images/viewicons.png' " +
                            "style='cursor:pointer;' " +
                            "onclick='viewIssueGrid(this)' /> &nbsp;&nbsp;" +
                             "<img src='../Assets/images/del.png' " +
                            "style='cursor:pointer;' " +
                            "onclick='delIssueGrid(this)' />" +
                            "</center>"
                    }
                ]
            });

            issueGridLoaded = true; // so it doesn't reinitialize
        }

    });

    var clientGridLoaded = false;
    $('button[data-bs-target="#navs-top-client"]').on('shown.bs.tab', function () {

        if (!clientGridLoaded) {
            showclientGrid();
            clientGridLoaded = true; // so it doesn't reinitialize
        }

    });

    function showclientGrid() {
        var mymodel = {
            p_client_gid: 0,
            p_action: "A"
         };
         $.ajax({ 
              type: "POST",
                 url: '@Url.Action("GetClientList", "Dashboard")',
                 data: JSON.stringify(mymodel),
                 dataType: "json",
                 contentType: 'application/json; charset=utf-8',
                success: function (data) {
                 console.log("Responses:", data);
                         if (data.authExpired) {
                            $.alert({
                                 title: 'Unauthorized',
                                content: response.message || 'Unauthorized User',
                                type: 'red',
                                buttons: {
                                    ok: {
                                        text: 'OK',
                                        action: function () {
                                            window.location.href = '/login/logout';
                                        }
                                    }
                                }
                            });
                            return;
                        }
                     let columns = [
                             {
                                title: "Action",
                                width: 70,
                                template: `
                                    <img src='../Assets/images/editicons.png'
                                         onclick="editGrid(this)"
                                         style="height:12px;width:12px;cursor:pointer;margin-right:10px;" />

                                    <img src='../Assets/images/del.png'
                                         onclick="deleteGrid(this)"
                                         style="height:12px;width:12px;cursor:pointer;" />
                                `
                            },
                         {
                             field: "client_gid",
                             title: "ID",
                             hidden: true
                         },                       
                         {
                             field: "client_code",
                             title: "Client Code"
                         },
                         {
                             field: "client_name",
                             title: "Client Name"
                         },
                         {
                             field: "client_type",
                             title: "Client Type"
                         },
                         {
                                field: "client_country",
                                title: "Client Country"
                         },
                         {
                                field: "client_state",
                                 title: "Client State"
                         },
                        {
                                field: "client_city",
                                title: "Client City"
                        }                      

                     ];
                     $('#clientListGrid').append('<div id="example" class="table-responsive text-nowrap" id="chk1"><table id="grid" data-bind="source: gridRows" class="table table-sm" style="width:100%;height: 358px;line-height:1em;font-size:12px;border-bottom: 1px solid #e1e1e1;"></table></div>');
                     var gridData = JSON.parse(data._data);                    
                     $("#grid").kendoGrid({
                         dataSource: {
                         data: gridData,
                             pageSize: 10
                         },
                         height: 358,
                         pageable: {
                             pageSizes: [10, 20, 30],
                             refresh: true
                         },
                         sortable: true,
                         filterable: true,
                         resizable: true,
                         columns: columns,
                             dataBound: function () {
                                var grid = this;
                                grid.columns.forEach(function (col, index) {
                                    // grid.autoFitColumn(index);
                                });
                            }
                     });
                 }
         });
    }

    function editGrid(e) {
        var grid = $("#grid").data("kendoGrid");
        var row = $(e).closest("tr");
        var dataItem = grid.dataItem(row);
        var client_gid = dataItem.client_gid;
        console.log("Edit client_gid:", client_gid);        
        sessionStorage.setItem("edit_client_gid", client_gid);
        window.location.href = "../ClientSetup/ClientSetup";
    }

     function deleteGrid(e) {
        var grid = $("#grid").data("kendoGrid");
        var row = $(e).closest("tr");
        var dataItem = grid.dataItem(row);
        var client_gid = dataItem.client_gid;
        console.log("Edit client_gid:", client_gid);    
        $.confirm({
                icon: 'fa fa-warning',
                    title: 'IPO Web',
                    autoClose: 'cancel|10000',
                    theme: 'blue',
                    animationSpeed: 700,
                    content: 'Are you sure do you want to delete this record!',
                    type: 'orange',
                    buttons: {
                    confirm: function () {
                                var mymodel = {
                                    in_client_gid:client_gid,  
                                    in_client_name: '',
                                    in_client_type:'',
                                    in_client_cin:'',
                                    in_client_contact_person:'',
                                    in_client_mob_no:'',
                                    in_client_email_id:'',
                                    in_client_addr:'',
                                    in_client_country:'',
                                    in_client_state:'',
                                    in_client_city:'',
                                    in_client_pincode:'',
                                    in_insert_by:'',
                                    in_update_by:"@userName",
                                    in_action: "D"                                    
                                }                            
                                $.ajax({
                                    type: "Post",
                                    url: '@Url.Action("IudClient", "ClientSetup")',
                                    data: JSON.stringify(mymodel),
                                    dataType: "json",
                                    contentType: 'application/json; charset=utf-8',
                                    success: function (response) {
                                            if (response.authExpired) {
                                                $.alert({
                                                     title: 'Unauthorized',
                                                    content: response.message || 'Unauthorized User',
                                                    type: 'red',
                                                    buttons: {
                                                        ok: {
                                                            text: 'OK',
                                                            action: function () {
                                                                window.location.href = '/login/logout';
                                                            }
                                                        }
                                                    }
                                                });
                                                return;
                                            }
                                    var result = JSON.parse(response._data);                                       
                                             if (result.length > 0) {
                                            $.alert({
                                            title: 'IPO Web',
                                            content: result[0].result,
                                            type: 'green',
                                        });
                                        $("#grid").data("kendoGrid").dataSource.read();
                                         $("#grid").data("kendoGrid").refresh();
                                       setTimeout(() => {
                                               window.location.href = "../Dashboard/Dashboard?tab=client";
                                        }, 3000);
                                    }
                                    }
                        });
                    },
                        cancel: function () {
                            $.alert({
                                icon: 'fa fa-success',
                                title: 'IPO Web',
                                theme: 'dark',
                                content: 'Delete Canceled.!',
                                type: 'blue',
                                animationSpeed: 700,
                            });
                        },
        }
        });
    }

</script>
