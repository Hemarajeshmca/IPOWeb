<!DOCTYPE html>
<html>  
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Dashboard</title>
    <style>       

        .nav-tabs .nav-link.active, .nav-tabs .nav-item.show .nav-link {
            background-color: #027ed1 !important;
            color: #fff !important;
        }

        .nav-tabs .nav-item .nav-link:not(.active) {
            background-color: #716969;
            color: #fff;
        }
       #legends {            
            border-radius: 10px;           
            width: 23%;
            margin: 10px;
            padding: 8px;
        }
        #border {
            border: 1px solid #efdada;          
            border-radius: 10px;
        }
        p {
            text-align: center;
            color: #fff;
        }

        /* Normal rows */
        #clientListGrid .k-grid-content tr td {
            background-color: #ffffff;
            border-bottom: 1px solid #dcdcdc;
            color:#000;
        }

        /* Alternate rows */
        #clientListGrid .k-grid-content tr.k-alt td {
            background-color: #fff !important;
            color: #000;
            border-bottom: 1px solid #dcdcdc;
        }
        /* Cell borders */
        #clientListGrid td {
            border: 1px solid #cfd8dc;
        }

        #clientListGrid .k-grid-content tr:last-child td {
            border-bottom: 1px solid #dcdcdc !important;
        }

        /* Compact row height */
        #clientListGrid .k-grid-content td {
            padding-top: 2px;
            padding-bottom: 2px;
        }

        /* Fixed layout */
        #clientListGrid .k-grid-header table,
        #clientListGrid .k-grid-content table {
            table-layout: fixed;
            width: 100%;
        }

        /* Prevent wrapping */
        #clientListGrid .k-grid-header th,
        #clientListGrid .k-grid-content td {
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        #clientListGrid .k-grid-content td {
            padding-top: 2px;
            padding-bottom: 2px;
            line-height: 18px;
            font-size: 13px;
        }

        #clientListGrid .k-grid-header th {
            padding-top: 4px;
            padding-bottom: 4px;
            line-height: 18px;
            font-size: 13px;
        }

        #clientListGrid .k-grid-content {
            height: 288px !important;
        }

            /* Normal rows */
        #issueListGrid .k-grid-content tr td {
                background-color: #ffffff;
                border-bottom: 1px solid #dcdcdc;
            }
            /* Alternate rows */
